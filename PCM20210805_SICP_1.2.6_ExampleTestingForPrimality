# ╔═╡ 7079c8a5-af5b-4083-b494-aaaf0ed1336a
# idiomatic Julia-code with 'rand'
function fermatTest1(n::Signed)::Bool 
	#-----------------------------------------------------------------------------
	tryIt(a) = expmod(a, n, n) == mod(a, n)     # long form as in theorem
	#-----------------------------------------------------------------------------
	n <= 1    ? false :
    n <= 3    ? true  :
    iseven(n) ? false : tryIt(rand(1:n-1))      # 1 < rand < (n-1)
end # fermat_test1

