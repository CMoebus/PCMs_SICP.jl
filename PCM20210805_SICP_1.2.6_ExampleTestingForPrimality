# ╔═╡ 9979c1e4-349b-4e0a-87a0-39de45ecdf4c
function isPrime2(n) 
	#-------------------------------------------
	remainder = %          # idiomatic Julia '%'
	#-------------------------------------------
	isDivisor(a, b)   = remainder(b, a) == 0
	#-------------------------------------------
	smallestDivisor(n) = findDivisor(n, 2)
	#-----------------------------------------------------------------------------
	function findDivisor(n, testDivisor)  
		testDivisor^2 > n ? n : 
		isDivisor(testDivisor, n) ? testDivisor : 
			findDivisor(n, testDivisor + 1)
	end # function findDivisor
	#-----------------------------------------------------------------------------
	n <= 1    ? false :
    n <= 3    ? true  :
    iseven(n) ? (false, smallestDivisor(n)) :   # ==> (false, prime factor)
	n == smallestDivisor(n) ? true : 
		(false, smallestDivisor(n))             # ==> (false, prime factor)
end # function isPrime2

