# ╔═╡ e878c3e1-21b9-47cd-ae57-6814dbeae2d0
function witness(j, a, n)          # witness for compositeness
	#-------------------------------------------------------------------------
	xi = -1
	# decompose n - 1 = 2^t * u with isodd(u)
	u = n - 1
	t = 0
	while u % 2 == 0               #  while iseven(u)
		u ÷= 2
		t += 1
	end # while
	nMin1 = n - 1
	twotu = 2^t*u
	# println("j = $j, n = $n, t = $t, u = $u, n-1 = $nMin1, = 2^t*u = $twotu")
	# isodd(u) now
	#-------------------------------------------------------------------------
	# a^u mod n
	x0 = powermod(a, u, n)   # CRLS, row 2
	# println("a = $a, u = $u, n = $n, x0 = $x0")
	for i in 1:t
		xi = mod(x0^2, n) 
		# println("xi = $xi")
		# # println("----------------------------------------------------")
		if xi == 1 && x0 ≠ 1 && x0 ≠ n - 1
			true && break          # found a nontrivial square root of 1
			                       # found a composite
		end # if
		x0 = xi
	end # for i
	if xi ≠ 1
		true                       # composite, definitely
	else
		false                      # prime or pseudoprime
	end # if
end # function witness

# ╔═╡ a3383b40-1779-4a23-aa56-96bd7de3564f
function millerRabin(n, ntrials)   # n > 2 is odd
	#-----------------------------------------------------------------------------
	j = 0
	witnessVal = false             # hypothesis: iscomposite(n) == false
	while !(j > ntrials) && witnessVal == false
		j += 1
		a = rand(2:n-2)
		witnessVal = witness(j, a, n)
		# println("witnessVal = $witnessVal")
	end # while
	#-----------------------------------------------------------------------------
	if witnessVal                  # if true  then definitely is composite
		false                      # if false then definitely is composite
	else
		true                       # almost surely prime or pseudoprime
	end # if
end # function millerRabin

