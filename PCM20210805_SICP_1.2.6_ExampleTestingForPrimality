# ╔═╡ 36ccf5f4-2106-4055-a255-457fe6e88185
# 'n' in local functions suppressed 
function isPrime3(n::Signed)::Bool
	#-----------------------------------------------------------
	isDivisor(a, b) = rem(b, a) == 0 
	#-----------------------------------------------------------
	smallestDivisor()::Signed = findDivisor(2)::Signed
	#-----------------------------------------------------------
	function findDivisor(testDivisor::Signed)::Signed  
	  while !((testDivisor^2 > n) || isDivisor(testDivisor, n))
			testDivisor += 1
	  end # while
	  testDivisor^2 > n ? n : testDivisor
	end # function findDivisor
	#-----------------------------------------------------------	
	n <= 1    ? false :
    n <= 3    ? true  :
    iseven(n) ? false : n == smallestDivisor()::Signed
end # function isPrime3

