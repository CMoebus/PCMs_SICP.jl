# ╔═╡ 2beafb91-5227-45eb-bb09-138128713268
# function-wide scope of 'n';  suppressed in local functions
function isPrime4(n::Signed)::Bool
	#------------------------------------------------------
	isDivisor(a::Signed, b::Signed)::Bool = rem(b, a) == 0 
	#------------------------------------------------------
	function smallestDivisor()::Signed
		testDivisor = 2
		for i = 2:round(Int,√n)
			testDivisor = i
			isDivisor(testDivisor, n) && break
		end # for
		isDivisor(testDivisor, n) ? testDivisor : n
	end # function smallestDivisor
	#------------------------------------------------------
	n <= 1    ? false :
    n <= 3    ? true  :
    iseven(n) ? false : n == smallestDivisor() 
end # function isPrime4

