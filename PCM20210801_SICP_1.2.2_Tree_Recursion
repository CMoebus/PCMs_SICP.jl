# ╔═╡ 7efd9e26-7ede-49fe-8d06-0f30a3c76d56
#-------------------------------------------------------------------------
function fib7(n::Signed)::Signed
#-------------------------------------------------------------------------
  # fib_iter(a, b, count) = count == 0 ? b : fib_iter(a + b, a, count - 1)
#-------------------------------------------------------------------------
  # fib_iter(1, 0, n)
#-------------------------------------------------------------------------
	a, b, count  = 1, 0, n             # parallel assignment of state vars
	while !(count == 0)                       # while loop
		a, b, count = a + b, a, count - 1     # parallel assignment
	end
	# in the case 'count == 0'
	b
end # function fib7

