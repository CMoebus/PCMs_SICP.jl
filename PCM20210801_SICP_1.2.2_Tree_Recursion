# ╔═╡ a76d6928-2136-4ac7-a1c4-dc50926005af
# coin = default positional parameter with default value
function myCountChange(amount, coin=50)  
	#------------------------------------------------------------------------------
	nextSmallerCoin(coin) =
	  coin == 50 ? 25 :
      coin == 25 ? 10 :
      coin == 10 ?  5 : 
      coin ==  5 ?  1 : 0
	#------------------------------------------------------------------------------
	amount == 0 ? 1 :
	coin   == 0 ? 0 :
  		amount < coin ? myCountChange(amount, nextSmallerCoin(coin)) :
  		amount ≥ coin ? 
			myCountChange(amount - coin, coin) +
	  			myCountChange(amount, nextSmallerCoin(coin)) : "error"
	#------------------------------------------------------------------------------
end # function myCountChange

